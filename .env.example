# ── App ──────────────────────────────────────────────────────────
# APP_ENV: development | staging | production
APP_ENV=development
APP_PORT=3001
# APP_LOG_LEVEL: debug | info | warn | error
APP_LOG_LEVEL=debug
# APP_LOG_FORMAT: text (dev) | json (prod)
APP_LOG_FORMAT=text

# ── Firebird (single source of truth — Microsip + nuestras tablas MSP_*) ─
FB_HOST=localhost
FB_PORT=3050
FB_DATABASE=/firebird/data/MUEBLERA.FDB
FB_USER=SYSDBA
FB_PASSWORD=masterkey
# Charset: UTF8 lets the Firebird server transcode strings so Go stays
# UTF-8 native end to end. Switch to WIN1252 only when debugging parallel
# writes against the legacy Node API or a server pinned to WIN1252.
FB_CHARSET=UTF8
FB_POOL_SIZE=10
FB_WIRE_CRYPT=true
FB_WIRE_COMPRESS=false

# ── Firebase (autenticación) ─────────────────────────────────────
# Conditional gating (see internal/platform/config Firebase docs):
#   APP_ENV=production                         → FIREBASE_PROJECT_ID required.
#   APP_ENV=development + DEV_MODE=true        → FIREBASE_PROJECT_ID optional;
#                                                "dev:<uid>" tokens accepted.
#   anything else                              → required unless
#                                                ALLOW_UNCONFIGURED=true.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Development-only: accept "dev:<uid>[:<email>]" bearer tokens without
# verifying with Firebase. Refused outside APP_ENV=development.
FIREBASE_DEV_MODE=false
# Escape hatch: boot with the NotConfigured client so every authenticated
# request returns 401. Use only for staging/internal-tooling deployments.
FIREBASE_ALLOW_UNCONFIGURED=false
# Web API key del proyecto Firebase (Settings → General → Web API Key).
# Lo usan probes/seed scripts para canjear UID → ID token vía signInWithCustomToken.
# No es secreto en el sentido de service-account, pero pertenece a este proyecto.
FIREBASE_WEB_API_KEY=
# Email del usuario admin bootstrap (debe existir en Firebase Auth y en MSP_USUARIOS).
# Lo usan probes/seed scripts para autenticarse como admin.
ADMIN_EMAIL=
# Firebase Auth Emulator (solo para tests integration; ver docs/firebase-setup.md).
# Cuando está set, el SDK redirige tráfico al emulador en lugar de Google.
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ── Sync Microsip → Postgres ─────────────────────────────────────
MICROSIP_SYNC_ENABLED=true
MICROSIP_SYNC_INTERVAL=5s
MICROSIP_SYNC_BATCH_SIZE=500

# ── Microsip catalog (read-only /v2/almacenes, /v2/zonas-cliente) ─
# Lista de PRECIO_EMPRESA_IDs filtrada por el endpoint de artículos
# por almacén. Cambiar sin recompilar si cambian las listas de precios.
MICROSIP_PRICE_LIST_IDS=42,8437,6925

# ── Observabilidad ───────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=msp-api

# ── HTTP ─────────────────────────────────────────────────────────
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s
HTTP_MAX_BODY_SIZE_MB=10
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Failed-intent capture (see internal/platform/failedintent + ADR-0005) ───
# Retention window for captured 4xx/5xx requests. The janitor purges rows
# older than this. Default: 90 days.
FAILED_INTENT_RETENTION_DAYS=90

# Maximum bytes of the request body captured per intent. Bodies larger than
# this are truncated and Intent.BodyTruncated is set to true. Default: 262144
# (256 KiB).
FAILED_INTENT_BODY_CAP_BYTES=262144

# Directory for multipart-body blobs captured by the failedintent middleware.
# Defaults to STORAGE_DIR/failed-intents when unset. Each blob is 0o600 and
# named after the intent UUID.
FAILEDINTENT_BLOB_DIR=

# Hard cap (in bytes) per multipart blob. Requests whose body exceeds this
# are still captured as intents but with BodyBlobPath="" and BodyTruncated=true.
# Default: 52428800 (50 MiB).
FAILEDINTENT_MAX_MULTIPART_BYTES=52428800

# ── Inventario (Microsip traspaso knobs) ─────────────────────────
# IDs Microsip usados por el módulo inventario al crear traspasos y
# resolver el almacén de venta. Coinciden con la API legacy Node.
# Cambiarlos requiere coordinación — ver docs/ops/inventario-cutover.md.
INVENTARIO_ALMACEN_DESTINO_VENTAS_ID=11058
INVENTARIO_CONCEPTO_IN_SALIDA_ID=36
INVENTARIO_CONCEPTO_IN_ENTRADA_ID=25
INVENTARIO_SUCURSAL_ID=225490

# ── Storage (ventas blobs) ───────────────────────────────────────
# Image uploads are written under STORAGE_DIR on local disk. The
# on-prem Windows Server deploy uses a directory served from a fixed
# path on the file system.
STORAGE_DIR=./var/uploads

# ── Image processor (server-side resize + recompress) ────────────
# The processor decodes incoming image uploads, caps the long side at
# MAX_LONG_SIDE_PX, and re-encodes with JPEG quality JPEG_QUALITY.
# Disable to make uploads pass through verbatim (NoOp impl).
IMAGEPROCESSOR_ENABLED=true
IMAGEPROCESSOR_MAX_LONG_SIDE_PX=1920
IMAGEPROCESSOR_JPEG_QUALITY=85
# png.CompressionLevel: -1 default, 0 no compression, -2 best speed, -3 best compression
IMAGEPROCESSOR_PNG_COMPRESSION=-1
# Hard cap on the source body. Uploads above this are rejected before decode.
IMAGEPROCESSOR_MAX_INPUT_BYTES=15728640
# Re-encode WebP inputs as JPEG (golang.org/x/image/webp is decode-only).
IMAGEPROCESSOR_WEBP_TO_JPEG=true
# Skip decode+encode when the input is already compact (size + dimensions fit).
IMAGEPROCESSOR_PRESERVE_SMALL=true
IMAGEPROCESSOR_SMALL_IMAGE_BYTES=524288

# ── Meilisearch (clientes directory search) ─────────────────────
# Full-text search engine for the clientes hub directory.
# Dev: start with `make meilisearch-up` (http://localhost:7700, no auth).
# Prod: run meilisearch.exe via nssm on Windows Server; set a master key.
#
# Conditional gating (see internal/platform/config Meilisearch docs):
#   APP_ENV=production              → MEILISEARCH_URL required.
#   any other env                  → required unless
#                                    MEILISEARCH_ALLOW_UNCONFIGURED=true.
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=
# UID of the clientes Meilisearch index. Change only when migrating indexes.
MEILISEARCH_INDEX_NAME=clientes
# How often the background reconcile worker syncs Firebird → Meilisearch.
MEILISEARCH_SYNC_INTERVAL=5m
# Escape hatch: boot with the NotConfigured client so search calls return
# ErrMeilisearchNotConfigured. Use only for envs where search is not needed.
MEILISEARCH_ALLOW_UNCONFIGURED=false

# ── Tests ────────────────────────────────────────────────────────
# Firebird-backed integration tests gate on FB_DATABASE (same value as the
# main app uses above). Set the var and run `make test-firebird-all` to
# exercise the platform + module integration suites against the dev
# Firebird container. Per ADR-0008 there is no separate test-DB target —
# `fbtestutil.WithTestTransaction` wraps every integration test in a
# rollback-only transaction so the shared dev DB never accumulates state.
