# ── App ──────────────────────────────────────────────────────────
APP_ENV=development             # development | staging | production
APP_PORT=3001
APP_LOG_LEVEL=debug             # debug | info | warn | error
APP_LOG_FORMAT=text             # text (dev) | json (prod)

# ── Postgres (nuestra DB) ────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=msp
PG_PASSWORD=msp
PG_DATABASE=msp_dev
PG_SSLMODE=disable
PG_MAX_OPEN_CONNS=25
PG_MAX_IDLE_CONNS=5

# ── Firebird (Microsip — solo lectura desde nuestra app) ─────────
FB_HOST=localhost
FB_PORT=3050
FB_DATABASE=/firebird/data/MUEBLERA.FDB
FB_USER=SYSDBA
FB_PASSWORD=masterkey
FB_CHARSET=WIN1252
FB_POOL_SIZE=10

# ── Firebase (autenticación) ─────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Sync Microsip → Postgres ─────────────────────────────────────
MICROSIP_SYNC_ENABLED=true
MICROSIP_SYNC_INTERVAL=5s
MICROSIP_SYNC_BATCH_SIZE=500

# ── Observabilidad ───────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=msp-api

# ── HTTP ─────────────────────────────────────────────────────────
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s
HTTP_MAX_BODY_SIZE_MB=10
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Tests ────────────────────────────────────────────────────────
# When set, integration tests reuse this Postgres instead of booting
# a per-process testcontainers Postgres. Bring one up with `make db-test-up`
# and export the URL with `make -s db-test-url`. Unset → testcontainers.
# TEST_DATABASE_URL=postgres://test:test@localhost:5499/msp_template?sslmode=disable
